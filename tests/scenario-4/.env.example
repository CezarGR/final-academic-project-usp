# Seed no Atlas (mesma URI usada pela API na nuvem).
SPRING_DATA_MONGO_DB_URI=mongodb+srv://USUARIO:SENHA@CLUSTER.mongodb.net/transactiondb?appName=transaction-api$maxPoolSize=100&minPoolSize=10

# Prometheus para Grafana e planilha: defina em config.json → prometheusUri.
# O Grafana roda em Docker: use URL que o *container* alcance (IP público da EC2,
# DNS interno da VPC, ou host.docker.internal no Linux pode exigir extra_hosts).
