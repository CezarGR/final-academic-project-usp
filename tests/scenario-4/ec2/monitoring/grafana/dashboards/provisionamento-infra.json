{
  "uid": "provisionamento-infra",
  "title": "Provisionamento de Infraestrutura - API de Transações",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "tags": ["performance", "provisionamento", "pesquisa"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Uso de CPU (%)",
      "description": "Percentual de utilização da CPU pelo container da aplicação.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"transaction-api\"}[1m]) * 100",
          "legendFormat": "Uso de CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Utilização de CPU (%)",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Saturação de CPU (%)",
      "description": "Relação entre o uso atual de CPU e o limite alocado ao container.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"transaction-api\"}[1m]) / 1.5",
          "legendFormat": "Saturação"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Uso de Memória (GB)",
      "description": "Quantidade de memória RAM utilizada pela aplicação.",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=\"transaction-api\"} / 1024 / 1024 / 1024",
          "legendFormat": "Memória utilizada"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Memória utilizada (GB)",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Pressão de Memória (%)",
      "description": "Percentual de uso da memória em relação ao limite configurado.",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=\"transaction-api\"} / container_spec_memory_limit_bytes{name=\"transaction-api\"}",
          "legendFormat": "Pressão de memória"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latência P95 (ms)",
      "description": "Tempo de resposta em milissegundos abaixo do qual 95% das requisições são atendidas.",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "Latência P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Latência P95 (ms)",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Taxa de Requisições (RPS)",
      "description": "Número de requisições processadas por segundo pela aplicação.",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "Requisições por segundo"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Requisições por segundo (RPS)",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Uso de Threads do Tomcat",
      "description": "Número de threads ocupadas e limite máximo configurado no servidor Tomcat.",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads",
          "legendFormat": "Threads em uso"
        },
        {
          "expr": "tomcat_threads_config_max_threads",
          "legendFormat": "Threads máximas"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Número de threads",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Threads da JVM",
      "description": "Quantidade de threads ativas e pico de threads da JVM.",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Threads ativas"
        },
        {
          "expr": "jvm_threads_peak_threads",
          "legendFormat": "Pico de threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Número de threads",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Requisições por Status (Sucesso vs Erro)",
      "description": "Quantidade de requisições por segundo separadas entre sucesso (2xx/3xx) e erro (4xx/5xx).",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"2..|3..\"}[1m]))",
          "legendFormat": "Sucesso (2xx/3xx)"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "Erro (4xx/5xx)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Taxa (requisições/s)",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Taxa de Erro (%)",
      "description": "Percentual de requisições que resultaram em erro (4xx e 5xx).",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "Taxa de erro"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 15,
            "showPoints": "never",
            "axisPlacement": "auto",
            "axisLabel": "Taxa de erro (0–100%)",
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "time" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Tempo" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    }
  ]
}
