# Volume externo TSDB do Prometheus (crie com: docker volume create <nome>). run-tests.py define sozinho.
PROMETHEUS_DATA_VOLUME_NAME=scenario_2_1_execution

# MongoDB no container (rede Docker): use exatamente esta URI para o serviço app.
SPRING_DATA_MONGO_DB_URI=mongodb://mongo:27017/transactiondb?maxPoolSize=100&minPoolSize=10
SPRING_DATA_MONGO_DB_AUTO_INDEX_CREATION=true
SERVER_TOMCAT_THREADS_MAX=100
SERVER_PORT=8080
